# Continuum V3 — Backend Environment Configuration
PORT=5000

# MongoDB URI (Replace with your own MongoDB Atlas connection string)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/continuum_v3?retryWrites=true&w=majority

# JWT Authentication secret key used for signing tokens
JWT_SECRET=continuum_v3_super_secure_jwt_signing_key_change_me_in_production

# WebRTC STUN/TURN Server Configuration (Defaults to Google free STUN server)
TURN_URL=stun:stun.l.google.com:19302
TURN_USERNAME=
TURN_CREDENTIAL=
